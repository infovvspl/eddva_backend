query: 
        SELECT c.*, 
               COALESCE((
                 SELECT json_agg(json_build_object('id', s.id, 'name', s.name))
                 FROM sections s WHERE s.class_id::text = c.id::text
               ), '[]'::json) as sections
        FROM classes c 
        WHERE c.institute_id=$1 
        ORDER BY c.name
       -- PARAMETERS: ["c259cd4e-b018-45e2-8e46-52a497ca49a1"]
